# Environment variables
# Copy this file to ".env" for local development. In Cloud Run, set these
# in the GCP Console (or via deploy.ps1 / --set-env-vars).

# Local port
PORT=3000

# GCS Bucket Name — leave empty for local dev to use the local data.json file.
# Set this only if you want the server to read/write the cloud storage bucket.
# GCS_BUCKET_NAME=your-bucket-name

# Admin-panel passcode. When set, this overrides the adminPasscode in data.json.
# Change this from the default before going live.
# ADMIN_PASSCODE=change-me

# Optional: customize the default admin account seeded into a fresh database.
# DEFAULT_ADMIN_NAME=ADMIN
# DEFAULT_ADMIN_SECRET=ADMN
